generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             Int             @id @default(autoincrement())
  email          String          @unique
  password_hash  String
  role           String
  created_at     DateTime        @default(now())
  companyProfile CompanyProfile?
  studentProfile StudentProfile?
  supportTickets SupportTicket[]
  sentMessages   Message[]       @relation("SentMessages")
  receivedMessages Message[]     @relation("ReceivedMessages")
  notifications  Notification[]

  @@map("users")
}

model StudentProfile {
  user_id                Int              @id
  full_name              String
  university             String?
  bio                    String?
  github_url             String?
  linkedin_url           String?
  phone                  String?
  twitter_url            String?
  website_url            String?
  cv_url                 String?
  profile_image_url      String?
  availability_status    String           @default("available")
  categories_of_interest String?
  graduation_year        Int?
  major                  String?
  is_verified            Boolean          @default(false)
  recommendations        Recommendation[]
  savedTasks             SavedTask[]
  user                   User             @relation(fields: [user_id], references: [id])
  skills                 StudentSkill[]
  submissions            Submission[]

  @@map("student_profiles")
}

model CompanyProfile {
  user_id                Int              @id
  company_name           String
  description            String?
  website_url            String?
  industry               String?
  location               String?
  logo_url               String?
  user                   User             @relation(fields: [user_id], references: [id])
  recommendationsWritten Recommendation[]
  tasks                  Task[]

  @@map("company_profiles")
}

model Skill {
  id       Int            @id @default(autoincrement())
  name     String         @unique
  students StudentSkill[]
  tasks    TaskSkill[]

  @@map("skills")
}

model StudentSkill {
  student_user_id Int
  skill_id        Int
  category        String         @default("General")
  level           Int            @default(3)
  skill           Skill          @relation(fields: [skill_id], references: [id])
  student         StudentProfile @relation(fields: [student_user_id], references: [user_id])

  @@id([student_user_id, skill_id])
  @@map("student_skills")
}

model Task {
  id                    Int            @id @default(autoincrement())
  company_user_id       Int
  title                 String
  description           String?
  reward_type           String?
  status                String?
  deadline              DateTime?
  employment_type       String?
  location              String?
  created_at            DateTime       @default(now())
  detail_body           String?
  detail_title          String?
  reward_amount         String?
  budget                String?
  category              String?
  certificate_issuer    String?
  certificate_name      String?
  currency              String?
  experience_level      String?
  internship_department String?
  internship_duration   String?
  internship_is_paid    String?
  positions             Int?
  preferred_major       String?
  subcategory           String?
  work_type             String?
  savedTasks            SavedTask[]
  submissions           Submission[]
  requiredSkills        TaskSkill[]
  company               CompanyProfile @relation(fields: [company_user_id], references: [user_id])

  @@map("tasks")
}

model TaskSkill {
  task_id             Int
  skill_id            Int
  is_required         Boolean @default(true)
  level               Int     @default(5)
  years_of_experience Int?
  skill               Skill   @relation(fields: [skill_id], references: [id])
  task                Task    @relation(fields: [task_id], references: [id])

  @@id([task_id, skill_id])
  @@map("task_skills")
}

model Submission {
  id                      Int            @id @default(autoincrement())
  task_id                 Int
  student_user_id         Int
  status                  String?
  submission_content      String?
  submitted_at            DateTime       @default(now())
  ai_match_score          Float?
  estimated_delivery_days Int?
  proposed_budget         String?
  ai_match_details        Json?
  review                  Review?
  student                 StudentProfile @relation(fields: [student_user_id], references: [user_id])
  task                    Task           @relation(fields: [task_id], references: [id])

  @@map("submissions")
}

model Review {
  submission_id Int            @id
  rating        Int?
  feedback      String?
  awardedBadges AwardedBadge[]
  submission    Submission     @relation(fields: [submission_id], references: [id])

  @@map("reviews")
}

model Badge {
  id       Int            @id @default(autoincrement())
  name     String
  icon_url String?
  awarded  AwardedBadge[]

  @@map("badges")
}

model AwardedBadge {
  review_id Int
  badge_id  Int
  badge     Badge  @relation(fields: [badge_id], references: [id])
  review    Review @relation(fields: [review_id], references: [submission_id])

  @@id([review_id, badge_id])
  @@map("awarded_badges")
}

model Recommendation {
  id              Int            @id @default(autoincrement())
  company_user_id Int
  student_user_id Int
  content         String
  created_at      DateTime       @default(now())
  company         CompanyProfile @relation(fields: [company_user_id], references: [user_id])
  student         StudentProfile @relation(fields: [student_user_id], references: [user_id])

  @@map("recommendations")
}

model SupportTicket {
  id         Int      @id @default(autoincrement())
  user_id    Int
  subject    String
  message    String
  status     String   @default("open")
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id])

  @@map("support_tickets")
}

model SavedTask {
  student_user_id Int
  task_id         Int
  saved_at        DateTime       @default(now())
  student         StudentProfile @relation(fields: [student_user_id], references: [user_id])
  task            Task           @relation(fields: [task_id], references: [id])

  @@id([student_user_id, task_id])
  @@map("saved_tasks")
}

model skill_ontology {
  id          Int    @id @default(autoincrement())
  skill_name  String @db.VarChar(255)
  parent_name String @db.VarChar(255)

  @@unique([skill_name, parent_name])
}

model Message {
  id          Int      @id @default(autoincrement())
  sender_id   Int
  receiver_id Int
  content     String
  is_read     Boolean  @default(false)
  created_at  DateTime @default(now())

  sender      User     @relation("SentMessages", fields: [sender_id], references: [id])
  receiver    User     @relation("ReceivedMessages", fields: [receiver_id], references: [id])

  @@map("messages")
}

model Notification {
  id          Int      @id @default(autoincrement())
  user_id     Int
  title       String
  message     String
  type        String   @default("info")
  link        String?
  is_read     Boolean  @default(false)
  created_at  DateTime @default(now())

  user        User     @relation(fields: [user_id], references: [id])

  @@map("notifications")
}
